{
  "permissions": {
    "allow": [
      "WebSearch",
      "mcp__plugin_supabase_supabase__list_projects",
      "mcp__plugin_supabase_supabase__apply_migration",
      "mcp__plugin_supabase_supabase__list_migrations",
      "mcp__plugin_supabase_supabase__get_logs",
      "mcp__plugin_supabase_supabase__execute_sql",
      "mcp__cloudflare__worker_list",
      "mcp__cloudflare__workers_analytics_search",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__fill",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__get_network_request",
      "mcp__chrome-devtools__new_page",
      "mcp__chrome-devtools__wait_for",
      "WebFetch(domain:geminicli.com)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "chrome-devtools",
    "cloudflare",
    "github"
  ],
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "other|prompt_input_exit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\n💡 Reminder: Did you run /session-end before leaving?\\n'"
          }
        ]
      }
    ]
  }
}
